# Healthcare ETL Pipeline — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── PostgreSQL Data Warehouse ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=healthcare_dw
DB_USER=etl_user
DB_PASSWORD=your_password_here

# ── Azure Data Lake Storage Gen2 (optional) ───────────────
# Leave blank to skip Azure uploads and use local Parquet only
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_CONTAINER=healthcare-claims

# ── Email Alerting ─────────────────────────────────────────
ALERT_EMAIL=phanikumarda@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Pipeline Settings ──────────────────────────────────────
DEFAULT_SOURCE_PATH=data/raw
LOG_LEVEL=INFO
MAX_NULL_PCT=0.10
